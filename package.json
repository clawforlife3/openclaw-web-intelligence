{
  "name": "openclaw-web-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Web Intelligence Gateway",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract": "tsx src/scripts/run-extract.ts",
    "search": "tsx src/scripts/run-search.ts",
    "map": "tsx src/scripts/run-map.ts",
    "crawl": "tsx src/scripts/run-crawl.ts",
    "cache": "tsx src/scripts/run-cache.ts"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "ddgs": "^1.0.4",
    "playwright": "^1.58.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
