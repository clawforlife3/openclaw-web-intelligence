{
  "name": "openclaw-web-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Web Intelligence Gateway",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/observability.spec.ts tests/proxy-pool.spec.ts tests/ratelimit-advanced.spec.ts tests/session-store.spec.ts tests/challenge.spec.ts tests/orchestrator.spec.ts tests/dashboard.spec.ts",
    "test:redis": "vitest run tests/redis-queue.spec.ts tests/redis-queue.integration.spec.ts",
    "test:proxy": "vitest run tests/proxy-pool.spec.ts tests/proxy-integration.spec.ts",
    "test:watch": "vitest",
    "extract": "tsx src/scripts/run-extract.ts",
    "search": "tsx src/scripts/run-search.ts",
    "research": "tsx src/scripts/run-research.ts",
    "task-registry": "tsx src/scripts/run-task-registry.ts",
    "crawl-domain": "tsx src/scripts/run-crawl-domain.ts",
    "monitor-topic": "tsx src/scripts/run-monitor-topic.ts",
    "map": "tsx src/scripts/run-map.ts",
    "crawl": "tsx src/scripts/run-crawl.ts",
    "monitor": "tsx src/scripts/run-monitor.ts",
    "cache": "tsx src/scripts/run-cache.ts",
    "worker": "tsx src/scripts/crawl-worker.ts",
    "dashboard": "tsx src/scripts/run-dashboard.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.1.2",
    "ddgs": "^1.0.4",
    "ioredis": "^5.10.0",
    "playwright": "^1.58.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
